# Copy this file to .env and fill in your secrets.
# Never commit the real .env; it is already in .gitignore.

# Postgres connection
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=gdelt
POSTGRES_USER=gdelt_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_SCHEMA=public

# Downloader settings
GDELT_START_DATE=2025-01-01
GDELT_END_DATE=
GDELT_INTERVAL_MINUTES=15
OUTPUT_DIR=workspace/data/raw

# Optional: HTTP
REQUEST_TIMEOUT_SECONDS=30
