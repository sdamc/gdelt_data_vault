# Copy this file to .env and fill in your secrets.

# Postgres connection
POSTGRES_DB= gdelt
POSTGRES_USER=CHANGEME
POSTGRES_PASSWORD=CHANGEME
POSTGRES_HOST=CHANGEME
POSTGRES_PORT=CHANGEME

# Ollama Configuration
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b

# Docker Port Binding (localhost-only for security, use 0.0.0.0 to expose to network)
HOST_BIND=127.0.0.1

# Workspace root (Docker container path)
WORKSPACE_ROOT=/workspace

# Data paths
BRONZE_PATH=/workspace/data/bronze
GOLD_PATH=/workspace/data/gold
